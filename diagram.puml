' ============================================================
' PACKAGE: orchestrator
' ============================================================
package "orchestrator" {

  class NodeFunctions << (M,lightgreen) module >> {
    - _agent_cache: dict[str, Any]
    --
    - _cfg(config) : AppConfig
    - _get_agent(cls, config) : Agent
    - _get_validation_critique(state, phase) : str
    - _trace(agent, reasoning, output_summary) : dict
    --
    + clarify_node(state, config) : dict
    + plan_node(state, config) : dict
    + rag_node(state, config) : dict
    + mcp_node(state, config) : dict
    + summary_node(state, config) : dict
    + validate_node(state, config) : dict
    + admin_node(state, config) : dict
    + report_node(state, config) : dict
    + assign_task_node(state, config) : dict
  }

  class RoutingFunctions << (M,lightgreen) module >> {
    + route_after_clarify(state) : str
    + route_after_admin_dispatch(state) : list[Send]
    + route_after_validation(state) : str
    + route_after_admin_check(state) : str | list
    + route_after_report(state) : str
  }

  class LangGraph << (G,salmon) StateGraph >> {
    + nodes: clarify, plan, admin_dispatch,\n  rag, mcp, validate, summary,\n  admin_check, report, assign_task
    --
    + build_graph(config, checkpointer) : CompiledGraph
  }

  class OrchestratorRunner {
    - graph: CompiledGraph
    - config: AppConfig
    --
    + __init__(config)
    + invoke(problem, desired_output) : GraphState
    + invoke_interactive(problem, ask_fn) : GraphState
    + stream(problem, desired_output) : AsyncIterator
    + run(problem, desired_output) : GraphState
    + stream_to_console(problem) : dict
    - _build_initial_state(problem, config, desired_output) : dict
  }

  NodeFunctions --> LangGraph : registers nodes
  RoutingFunctions --> LangGraph : registers edges
  OrchestratorRunner --> LangGraph : invokes
}

' ============================================================
' LANGGRAPH FLOW (Activity/Sequence style)
' ============================================================
package "Graph Flow" {

  rectangle "START" as GS #2ECC71
  rectangle "clarify" as GCL #3498DB
  rectangle "plan" as GPL #3498DB
  rectangle "admin_dispatch\n(Mode 1)" as GAD #E67E22
  rectangle "rag" as GRAG #9B59B6
  rectangle "mcp" as GMCP #9B59B6
  rectangle "validate" as GVL #E74C3C
  rectangle "summary" as GSM #1ABC9C
  rectangle "admin_check\n(Mode 2)" as GAC #E67E22
  rectangle "report" as GRP #3498DB
  rectangle "assign_task" as GAT #3498DB
  rectangle "END" as GE #E74C3C

  GS --> GCL
  GCL --> GPL : clear
  GCL --> GE : needs_clarification
  GPL --> GAD
  GAD --> GRAG : always (Send)
  GAD --> GMCP : if selected_tools (Send)
  GRAG --> GVL
  GMCP --> GVL
  GVL --> GSM : PASS (from rag/mcp)
  GVL --> GAC : PASS (from summary)
  GVL --> GRP : PASS (from admin_check sufficient)
  GVL --> GRAG : FAIL loop_back=rag
  GVL --> GMCP : FAIL loop_back=mcp
  GVL --> GSM : FAIL loop_back=summary (max retries)
  GSM --> GVL
  GAC --> GRP : sufficient
  GAC --> GRAG : need_more_rag (Send)
  GAC --> GMCP : need_more_mcp (Send)
  GAC --> GSM : need_more_summary
  GRP --> GVL
  GVL --> GAT : needs_assignment
  GVL --> GE : done
  GAT --> GE
}

' ============================================================
' CROSS-PACKAGE RELATIONSHIPS
' ============================================================

BaseAgent --> AppConfig : uses
BaseAgent --> SkillRegistry : loads skills
AdminAgent --> Inventory : reads inventory
RAGAgent --> RAGStore : searches
NodeFunctions --> FileWriter : calls write_all
NodeFunctions --> RAGStore : resets on plan

ClarificationAgent --> Prompts : CLARIFICATION_PROMPT
PlanningAgent --> Prompts : PLANNING_PROMPT
AdminAgent --> Prompts : ADMIN_DISPATCH_PROMPT\nADMIN_CHECK_PROMPT
RAGAgent --> Prompts : RAG_SYSTEM_PROMPT
MCPAgent --> Prompts : MCP_EXTRACTION_PROMPT
SummaryAgent --> Prompts : SUMMARY_SYSTEM_PROMPT
ValidationAgent --> Prompts : VALIDATION_SYSTEM_PROMPT
ReportAgent --> Prompts : REPORT_SYSTEM_PROMPT
AssignTaskAgent --> Prompts : TASK_ASSIGNMENT_SYSTEM_PROMPT

NodeFunctions --> ClarificationAgent : instantiates
NodeFunctions --> PlanningAgent : instantiates
NodeFunctions --> AdminAgent : instantiates
NodeFunctions --> RAGAgent : instantiates
NodeFunctions --> MCPAgent : instantiates
NodeFunctions --> SummaryAgent : instantiates
NodeFunctions --> ValidationAgent : instantiates
NodeFunctions --> ReportAgent : instantiates
NodeFunctions --> AssignTaskAgent : instantiates

GraphState --> PlanningOutput : plan
GraphState --> RAGOutput : rag_output
GraphState --> MCPOutput : mcp_output
GraphState --> SummaryOutput : summary_output
GraphState --> ValidationOutput : validation_output
GraphState --> AdminOutput : admin_output
GraphState --> WritingOutput : report_output
GraphState --> AssignTaskOutput : assign_output

SkillRegistry "1" *-- "0..*" WebSearchSkill : registered skill

@enduml
